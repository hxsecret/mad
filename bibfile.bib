@article{Bowen_Murphy_Cai_Khachaturov_Gleave_Pelrine_2025, 
    title={Scaling Trends for Data Poisoning in LLMs}, volume={39}, url={https://ojs.aaai.org/index.php/AAAI/article/view/34929}, 
    DOI={10.1609/aaai.v39i26.34929}, 
    abstractNote={LLMs produce harmful and undesirable behavior when trained on datasets containing even a small fraction of poisoned data. We demonstrate that GPT models remain vulnerable to fine-tuning on poisoned data, even when safeguarded by moderation systems. Given the persistence of data poisoning vulnerabilities in today’s most capable models, this paper investigates whether these risks increase with model scaling. We evaluate three threat models—malicious fine-tuning, imperfect data curation, and intentional data contamination—across 24 frontier LLMs ranging from 1.5 to 72 billion parameters. Our experiments reveal that larger LLMs are significantly more susceptible to data poisoning, learning harmful behaviors from even minimal exposure to harmful data more quickly than smaller models. These findings underscore the need for leading AI companies to thoroughly red team fine-tuning APIs before public release and to develop more robust safeguards against data poisoning, particularly as models continue to scale in size and capability.}, number={26}, journal={Proceedings of the AAAI Conference on Artificial Intelligence}, author={Bowen, Dillon and Murphy, Brendan and Cai, Will and Khachaturov, David and Gleave, Adam and Pelrine, Kellin}, 
    year={2025}, 
    month={Apr.}, 
    pages={27206–27214} }

